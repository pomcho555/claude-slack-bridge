# --- Slack (required) ---
# Bot User OAuth Token, starts with "xoxb-"
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token with connections:write scope, starts with "xapp-" (for Socket Mode)
SLACK_APP_TOKEN=xapp-...

# --- Access control (optional) ---
# Comma-separated Slack user IDs allowed to use the bot (e.g. U0123,U0456).
# Leave empty to allow everyone in the workspace. Strongly recommend setting this:
# anyone who can trigger the bot can run Claude Code on your machine.
ALLOWED_USERS=

# --- Claude Code (optional) ---
# Path/name of the claude binary.
CLAUDE_BIN=claude
# Directory Claude runs in (your project/repo). Defaults to where the bridge starts.
CLAUDE_WORKDIR=
# Permission mode for headless runs: acceptEdits | bypassPermissions | plan | default
CLAUDE_PERMISSION_MODE=acceptEdits
# Optional model override (e.g. claude-opus-4-8). Empty = account default.
CLAUDE_MODEL=
# Extra args appended to every claude invocation, space-separated (e.g. --add-dir /tmp)
CLAUDE_EXTRA_ARGS=
# Max seconds a single job may run before being killed (default 14400 = 4h).
CLAUDE_TIMEOUT=14400

# --- Outbound (optional) ---
# Default Slack channel ID that slack-claude-job / slack-claude-notify post to
# when a locally-started job finishes (e.g. C0123ABCD). The bot must be a member.
# Can be overridden per-call with --channel.
SLACK_NOTIFY_CHANNEL=

# --- Storage (optional) ---
# SQLite file mapping Slack threads <-> Claude sessions.
DB_PATH=bridge.db
